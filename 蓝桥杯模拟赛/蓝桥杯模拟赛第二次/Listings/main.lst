 124          // ================= ADC与光照计算 =================
 125          u8 cnt_adc;
 126          void adc_process()
 127          {
 128   1          float voltage;
 129   1      
 130   1          if(cnt_adc >= 10)
 131   1          {
 132   2              cnt_adc = 0;
 133   2              ch3 = read_adc(0x43); // 读取电位器
 134   2              voltage = (float)ch3 * 5.0 / 255.0;
 135   2      
 136   2              // 计算 Lux
 137   2              if(voltage < 0.3) lux_val = 10;
 138   2              else 
 139   2              {
 140   3                  lux_val = (u16)((voltage - 0.3) * 104.256 + 10);
 141   3                  if(lux_val > 500) lux_val = 500;
 142   3              }
 143   2          }
 144   1      }
