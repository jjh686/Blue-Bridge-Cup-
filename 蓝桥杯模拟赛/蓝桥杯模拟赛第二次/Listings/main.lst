  92          // ================= 修复闪烁后的 LED 处理函数 =================
  93          void vLed_process()
  94          {
  95   1          u8 led_bits = 0xFF; // 默认全灭 (1为灭，0为亮)
  96   1          static u8 led_old = 0xFF; // [新增] 用于记录上一次的 LED 状态
  97   1          
  98   1          // 1. 界面指示灯
  99   1          if(set_disp_mode == 0)
 100   1          {
 101   2              led_bits &= ~0x01; // L1亮 (检测界面)
 102   2          }
 103   1          else
 104   1          {
 105   2              led_bits &= ~0x02; // L2亮 (阈值界面)
 106   2          }
 107   1          
 108   1          // 2. 报警指示灯 L8
 109   1          // 条件：(当前温度 > 阈值) 且 (当前光照 > 阈值)
 110   1          if( ((temprt / 100) > temp_param) && (lux_val > lux_param) )
 111   1          {
 112   2              led_bits &= ~0x80; // L8亮
 113   2          }
 114   1          
 115   1          // 3. [核心修改] 只有当 LED 状态发生改变时，才操作硬件
 116   1          // 这样避免了主循环一直“轰炸”P0口，解决了与数码管扫描的冲突
C51 COMPILER V9.56.0.0   MAIN                                                              04/11/2026 19:30:23 PAGE 3   

 117   1          if(led_bits != led_old)
 118   1          {
 119   2              vP2P0_ctrl(0x80, led_bits);
 120   2              led_old = led_bits; // 更新旧状态
 121   2          }
 122   1      }
