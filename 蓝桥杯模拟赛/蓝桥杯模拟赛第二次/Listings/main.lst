 157          // ================= 数码管显示 =================
 158          void vSmg_process()
 159          {
 160   1          if(set_disp_mode == 0) // 检测界面
 161   1          {
 162   2              smg_buf[0] = 0x39; // C
 163   2              smg_buf[1] = smg_code[(temprt / 100) / 10];
 164   2              smg_buf[2] = smg_code[(temprt / 100) % 10];
 165   2              smg_buf[3] = 0x00;
