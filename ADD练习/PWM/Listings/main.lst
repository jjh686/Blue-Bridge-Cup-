  25          void vPWM_Prcocess()
  26          {
  27   1              cnt_pwm = cnt_pwm % 10 + 1;     //cnt_pwm的范围是1~10，共10个数，即定义了PWM的周期为1ms
  28   1              if(cnt_pwm <= (pwm_duty/10))
  29   1              {
  30   2                      led_ctrl=0x55;
  31   2                      
  32   2                      smg_buf[0]=smg_code[12345/10000];
  33   2                      smg_buf[1]=smg_code[12345/1000%10];     
  34   2                      smg_buf[2]=smg_code[12345/100%10];      
  35   2                      smg_buf[3]=smg_code[12345/10%10];       
  36   2                      smg_buf[4]=smg_code[12345%10];  
  37   2                      smg_buf[5]=0x00;        
  38   2                      smg_buf[6]=0x00;
  39   2                      smg_buf[7]=0x00;
  40   2              }               
  41   1              else
  42   1              {
  43   2                      led_ctrl=0xff;
  44   2                      
  45   2                      smg_buf[0]=0x00;
  46   2                      smg_buf[1]=0x00;        
  47   2                      smg_buf[2]=0x00;        
  48   2                      smg_buf[3]=0x00;        
  49   2                      smg_buf[4]=0x00;        
  50   2                      smg_buf[5]=0x00;        
  51   2                      smg_buf[6]=0x00;
  52   2                      smg_buf[7]=0x00;
  53   2              }
  54   1      }
