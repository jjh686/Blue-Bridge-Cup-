  33   2                      {
  34   3                              rx_cnt = 0;                     //方便下一次接收N个字节的指令
  35   3                              rx_flag = 1;            //接收完N个字节数据
  36   3                      }
  37   2          }
  38   1          if (TI)
  39   1          {
  40   2              TI = 0;                 //清除TI位
  41   2              busy = 0;               //清忙标志
  42   2          }
  43   1      }
  44          
  45          /*----------------------------
  46          串口接收空闲计时处理函数
  47          ----------------------------*/
  48          void vRxIdle_Process(void)
  49          {
  50   1              rx_idletime++;
  51   1              if(rx_idletime>=50)                     //过了50ms，串口还没有接收到数据，说明一次连续发送已经完成
  52   1              {
  53   2                      rx_idletime=0;
