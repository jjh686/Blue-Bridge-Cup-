  25          
  26          #define KEY_NO   0
  27          #define KEY_DOWN 1
  28          #define KEY_UP   2
  29          
  30          u8 vBTN_Read(void)
  31          {
  32   1              static u8 key_state = 0;
  33   1              u8 key_io = 0, key_val = 0;
  34   1              
  35   1              key_io = P3 & 0x0f;
  36   1              switch(key_state)
  37   1              {
  38   2                      case KEY_NO:
  39   2                              if(key_io!=0x0f) key_state = KEY_DOWN;
  40   2                      break;
  41   2                      
  42   2                      case KEY_DOWN:
  43   2                              if(key_io!=0x0f)
  44   2                              {
  45   3                                      if(key_io==0x0e) key_val = 7;
  46   3                                      if(key_io==0x0d) key_val = 6;
  47   3                                      if(key_io==0x0b) key_val = 5;
  48   3                                      if(key_io==0x07) key_val = 4;
  49   3                                      key_state = KEY_UP;
  50   3                              }
  51   2                              else
  52   2                                      key_state = KEY_NO;
  53   2                      break;
  54   2                              
