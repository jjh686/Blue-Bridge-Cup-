  80   1              smg_buf[0]=smg_code[s4_number/100];
  81   1              smg_buf[1]=smg_code[s4_number/10%10];
  82   1              smg_buf[2]=smg_code[s4_number%10];
  83   1              smg_buf[3]=0x00;
  84   1              smg_buf[4]=0x00;
