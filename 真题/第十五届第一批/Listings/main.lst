 145   2                      led_ctrl |= 0x01;      // 其他模式下熄灭
 146   2              }
 147   1      
 148   1              // 3. 处理 L2 (对应 0x02) 的逻辑 (使用互斥结构，解决状态覆盖问题)
 149   1              if(freq_ne555_jz < 0)
 150   1              {
 151   2                      led_ctrl &= ~0x02;     // 小于0时，常亮 (假设低电平点亮)
 152   2              }
 153   1              else if(freq_ne555_jz > set_Pf)
 154   1              {
 155   2                      // 大于设定值时，跟随节拍闪烁
 156   2                      if(blink_flag == 0)
 157   2                              led_ctrl &= ~0x02; // 点亮
 158   2                      else
 159   2                              led_ctrl |= 0x02;  // 熄灭
 160   2              }
 161   1              else
 162   1              {
 163   2                      led_ctrl |= 0x02;      // 正常范围内，熄灭
 164   2              }
 165   1          vP2P0_ctrl(0x80, led_ctrl);
 166   1      }
