 124          void vLed_Proc()
 125          {
 126   1              static u8 blink_flag = 0; // 0和1交替，作为全局的闪烁节拍标志
 127   1      
 128   1              // 1. 统一产生 200 个计数周期的闪烁节拍 (解决 led_cnt 被重复清零的冲突)
 129   1              if(led_cnt >= 200)
 130   1              {
 131   2                      led_cnt = 0;
 132   2                      blink_flag = !blink_flag; // 每次时间到，标志位翻转 (0变1，1变0，解决 k和b 逻辑错误)
 133   2              }
 134   1      
 135   1              // 2. 处理 L1 (对应 0x01) 的逻辑
 136   1              if(set_disp_mode == 0)
 137   1              {
 138   2                      if(blink_flag == 0)
 139   2                              led_ctrl &= ~0x01; // 点亮
 140   2                      else
 141   2                              led_ctrl |= 0x01;  // 熄灭
 142   2              }
 143   1              else
