  16          void vTimer2_Init(void)         //1毫秒@12.000MHz
  17          {
  18   1              AUXR &= 0xFB;           //定时器时钟12T模式
  19   1              T2L = 0x18;                     //设置定时初值
  20   1              T2H = 0xFC;                     //设置定时初值
  21   1              AUXR |= 0x10;           //定时器2开始计时
  22   1              IE2 |= 0x04;                    //开定时器2中断
  23   1              EA = 1;
  24   1      }
  25          
  26          
