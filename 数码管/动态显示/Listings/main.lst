   5          u8 smg_code[]={0x3F,0x06,0x5B,0x4F,0x66,0x6D,0x7D,0x07,0x7F,0x6F,0x00,0x3E,0x73};
   6          
   7          HexToBin led_ctrl,uln_ctrl;
   8          
   9          void vSystem_Init(void)
  10          {
