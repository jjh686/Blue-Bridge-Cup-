  29          void vLED_Process()
  30          {
  31   1              if(cnt_led_blink>=500)
  32   1              {
  33   2                      cnt_led_blink=0;
  34   2                      led_ctrl.b.b0 = ~led_ctrl.b.b0;
  35   2                      vDevice_Ctrl(0x80,led_ctrl.hex);
  36   2                      
  37   2                      led_blink_times++;
  38   2              }
  39   1              
  40   1              if(cnt_led_running>=100)
  41   1              {
  42   2                      cnt_led_running=0;
  43   2                      led_ctrl.b.b3 = ~(0x01>>led_shift);
  44   2                      led_ctrl.b.b4 = ~(0x02>>led_shift);
  45   2                      led_ctrl.b.b5 = ~(0x04>>led_shift);
  46   2                      led_ctrl.b.b6 = ~(0x08>>led_shift);
  47   2                      led_ctrl.b.b7 = ~(0x10>>led_shift);
  48   2                      vDevice_Ctrl(0x80,led_ctrl.hex);        
  49   2                      
  50   2                      led_shift++;
  51   2                      if(led_shift==5) 
  52   2                              led_shift=0;
  53   2              }
  54   1      }
