  16          
  17          void vTimer2_Init(void)         //1毫秒@12.000MHz
  18          {
  19   1              AUXR &= 0xFB;           //定时器时钟12T模式
  20   1              T2L = 0x18;                     //设置定时初值
  21   1              T2H = 0xFC;                     //设置定时初值
  22   1              AUXR |= 0x10;           //定时器2开始计时
  23   1              IE2 |= 0x04;                    //开定时器2中断
  24   1              EA = 1;
  25   1      }
  26          
  27          void main(void)
  28          {
  29   1              vSystem_Init();
  30   1              vTimer2_Init();
  31   1              while(1)
  32   1              {
  33   2              if(cnt_buzzer>=200)
  34   2              {
  35   3                      cnt_buzzer=0;
  36   3                      uln_ctrl.b.b6 = ~uln_ctrl.b.b6;
  37   3              }                       
  38   2                      vDelay_Ms(100);
  39   2              }
  40   1      }
  41          
  42          
  43          //中断服务程序
  44          void vTimer2_ISR() interrupt 12     //中断入口
