   1          #include "system.h"
   2          #include <intrins.h>
   3          #include "Delay.h"
   4          #include "Device.h"
   5          
   6          
   7          HexToBin led_ctrl,uln_ctrl;
   8          u16 cnt_buzzer;
   9          
  10          void vSystem_Init(void)
  11          {
  12   1              vDevice_Ctrl(0xa0,0);
  13   1              led_ctrl.hex=0xff;
