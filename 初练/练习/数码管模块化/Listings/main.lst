 405          
 406          //数码管(消除鬼影)
 407          u8 smg_code[]={0x3F,0x06,0x5B,0x4F,0x66,0x6D,0x7D,0x07,0x7F,0x6F,0x00,0x3E,0x73,0x76,0x79,0x38};
 408          
 409          HexToBin led_ctrl,uln_ctrl;
 410          
 411          void vSystem_Init(void)
 412          {
 413   1              vDevice_Ctrl(0xa0,0);           //关闭继电器与蜂鸣器    
 414   1              led_ctrl.hex=0xff;
 415   1              vDevice_Ctrl(0x80,led_ctrl.hex);                //关闭LED
 416   1      }
 417          
 418          void vTimer2_Init(void)         //1毫秒@12.000MHz
 419          {
 420   1              AUXR &= 0xFB;           //定时器时钟12T模式
 421   1              T2L = 0x18;             //设置定时初值
 422   1              T2H = 0xFC;             //设置定时初值
 423   1              AUXR |= 0x10;           //定时器2开始计时
 424   1              IE2 |= 0x04;        //开定时器2中断
C51 COMPILER V9.56.0.0   MAIN                                                              09/01/2025 15:50:00 PAGE 8   

 425   1              EA = 1;                         //开启总中断
 426   1      }
 427          
 428          u8 smg_buf[8];
 429          
 430          void vSMG_Process()
 431          {
 432   1              smg_buf[0]=smg_code[13];
 433   1              smg_buf[1]=smg_code[14];
 434   1              smg_buf[2]=smg_code[15];
 435   1              smg_buf[3]=smg_code[15];
 436   1              smg_buf[4]=smg_code[0];
 437   1              smg_buf[5]=0x00;
 438   1              smg_buf[6]=0x00;
 439   1              smg_buf[7]=0x00;
 440   1      }
 441          
 442          void main(void)
 443          {
 444   1              vSystem_Init();
 445   1              vTimer2_Init();
 446   1      
 447   1              while(1)
 448   1              {
 449   2                      vSMG_Process();
 450   2              }
 451   1      }
 452          
 453          void vSMG_Display()
 454          {
 455   1              static u8 i=0;
 456   1              vDevice_Ctrl(0xc0,0);
 457   1              vDevice_Ctrl(0xe0,~smg_buf[i]);
 458   1              vDevice_Ctrl(0xc0,0x01<<i);
 459   1              i = (i + 1) % 8;
 460   1      }
 461          
 462          //中断服务程序
 463          void vTimer_ISR() interrupt 12           //中断入口
 464          {
 465   1              vSMG_Display();
 466   1      }


