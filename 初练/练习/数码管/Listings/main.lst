 493          
 494          //数码管(消除鬼影)
 495          u8 smg_code[]={0x3F,0x06,0x5B,0x4F,0x66,0x6D,0x7D,0x07,0x7F,0x6F,0x00,0x3E,0x73,0x76,0x79,0x38};
 496          
 497          HexToBin led_ctrl,uln_ctrl;
 498          
 499          void vSystem_Init(void)
 500          {
 501   1              vDevice_Ctrl(0xa0,0);           //关闭继电器与蜂鸣器    
 502   1              led_ctrl.hex=0xff;
 503   1              vDevice_Ctrl(0x80,led_ctrl.hex);                //关闭LED
 504   1      }
 505          
 506          void vTimer2_Init(void)         //1毫秒@12.000MHz
 507          {
 508   1              AUXR &= 0xFB;           //定时器时钟12T模式
 509   1              T2L = 0x18;             //设置定时初值
 510   1              T2H = 0xFC;             //设置定时初值
 511   1              AUXR |= 0x10;           //定时器2开始计时
 512   1              IE2 |= 0x04;        //开定时器2中断
 513   1              EA = 1;                         //开启总中断
 514   1      }
 515          
 516          u8 smg_buf[8];
 517          
 518          void vSMG_Process()
 519          {
 520   1              smg_buf[0]=smg_code[13];
 521   1              smg_buf[1]=smg_code[14];
 522   1              smg_buf[2]=smg_code[15];
 523   1              smg_buf[3]=smg_code[15];
 524   1              smg_buf[4]=smg_code[0];
 525   1              smg_buf[5]=0x00;
 526   1              smg_buf[6]=0x00;
 527   1              smg_buf[7]=0x00;
 528   1      }
 529          
 530          void main(void)
 531          {
 532   1              vSystem_Init();
 533   1              vTimer2_Init();
 534   1      
 535   1              while(1)
 536   1              {
 537   2                      vSMG_Process();
 538   2              }
 539   1      }
 540          
 541          void vSMG_Display()
 542          {
 543   1              static u8 i=0;
 544   1              vDevice_Ctrl(0xc0,0);
 545   1              vDevice_Ctrl(0xe0,~smg_buf[i]);
 546   1              vDevice_Ctrl(0xc0,0x01<<i);
 547   1              i = (i + 1) % 8;
 548   1      }
C51 COMPILER V9.56.0.0   MAIN                                                              09/01/2025 15:49:57 PAGE 10  

 549          
 550          //中断服务程序
 551          void vTimer_ISR() interrupt 12           //中断入口
 552          {
 553   1              vSMG_Display();
 554   1      }


