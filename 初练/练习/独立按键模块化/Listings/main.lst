 632          void vSMG_Process()
 633          {
 634   1              smg_buf[0]=smg_code[s4_number/100];
 635   1              smg_buf[1]=smg_code[s4_number/10%10];
 636   1              smg_buf[2]=smg_code[s4_number%10];
 637   1              smg_buf[3]=0x00;
 638   1              smg_buf[4]=0x00;
 639   1              smg_buf[5]=0x00;
 640   1              smg_buf[6]=0x00;
 641   1              smg_buf[7]=0x00;
 642   1      }
