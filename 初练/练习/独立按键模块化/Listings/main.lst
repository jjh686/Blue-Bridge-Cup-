 591          u8 cnt_key;
 592          u8 s4_number;
 593          void vBTN_State_Process(void)
 594          {
 595   1              u8 key_val;
 596   1              if(cnt_key>=10)
 597   1              {
 598   2                      cnt_key=0;
 599   2                      key_val = vBTN_Read_State();
 600   2                      if(key_val==4)
 601   2                      {
 602   3                              s4_number++;
 603   3                      }
 604   2              }
 605   1      }
 606          
 607          void vBTN_ThreeLine_Process(void)
 608          {
 609   1              if(cnt_key>=10)
 610   1              {
C51 COMPILER V9.56.0.0   MAIN                                                              09/02/2025 16:03:24 PAGE 11  

 611   2                      cnt_key=0;
 612   2                      vBTN_Read_ThreeLine();
 613   2                      if(Trg & 0x08)
 614   2                      {
 615   3                              s4_number++;
 616   3                      }
 617   2                      if(Trg & 0x04)
 618   2                      {
 619   3                              s4_number--;
 620   3                      }
 621   2                      if(Trg & 0x02)
 622   2                      {
 623   3                              s4_number+=10;
 624   3                      }
 625   2                      if(Trg & 0x01)
 626   2                      {
 627   3                              s4_number-=10;
 628   3                      }
 629   2              }
 630   1      }
