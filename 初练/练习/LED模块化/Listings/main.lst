 195          
 196          void main(void)
 197          {
 198   1              vSystem_Init();
 199   1              led_ctrl.hex = 0x55;
 200   1              vDevice_Ctrl(0x80,led_ctrl.hex);
 201   1              
 202   1              buzzer_ctrl.b.b4 = 1;
 203   1              vDevice_Ctrl(0xa0,buzzer_ctrl.hex);
 204   1              while(1)
 205   1              {
 206   2                      led_ctrl.b.b1 = 1;
 207   2                      vDevice_Ctrl(0x80,led_ctrl.hex);
 208   2                      vDelay_Ms(200);
 209   2                      
 210   2                      led_ctrl.b.b1 = 0;
 211   2                      vDevice_Ctrl(0x80,led_ctrl.hex);
 212   2                      vDelay_Ms(200);
 213   2              }
