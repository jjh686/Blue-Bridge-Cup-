 779          u8 smg_buf[8];
 780          
 781          void vSMG_Process()
 782          {
 783   1              smg_buf[0]=smg_code[s4_number/100];
 784   1              smg_buf[1]=smg_code[s4_number/10%10];
 785   1              smg_buf[2]=smg_code[s4_number%10];
 786   1              smg_buf[3]=0x00;
 787   1              smg_buf[4]=0x00;
 788   1              smg_buf[5]=0x00;
 789   1              smg_buf[6]=0x00;
 790   1              smg_buf[7]=0x00;
 791   1      }
