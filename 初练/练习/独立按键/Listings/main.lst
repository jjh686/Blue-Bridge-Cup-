 674          HexToBin led_ctrl,uln_ctrl;
 675          
 676          void vSystem_Init(void)
 677          {
 678   1              vDevice_Ctrl(0xa0,0);           //关闭继电器与蜂鸣器    
 679   1              led_ctrl.hex=0xff;
 680   1              vDevice_Ctrl(0x80,led_ctrl.hex);                //关闭LED
 681   1      }
 682          
 683          void vTimer2_Init(void)         //1毫秒@12.000MHz
 684          {
 685   1              AUXR &= 0xFB;           //定时器时钟12T模式
 686   1              T2L = 0x18;             //设置定时初值
 687   1              T2H = 0xFC;             //设置定时初值
 688   1              AUXR |= 0x10;           //定时器2开始计时
 689   1              IE2 |= 0x04;        //开定时器2中断
 690   1              EA = 1;                         //开启总中断
 691   1      }
 692          
 693          #define KEY_NO   0
 694          #define KEY_DOWN 1
 695          #define KEY_UP   2
 696          
 697          u8 vBTN_Read_State(void)
 698          {
 699   1              static u8 key_state = 0;
 700   1              u8 key_io = 0, key_val = 0;
 701   1              
 702   1              key_io = P3 & 0x0f;
 703   1              switch(key_state)
 704   1              {
 705   2                      case KEY_NO:
 706   2                              if(key_io!=0x0f) key_state = KEY_DOWN;
 707   2                      break;
 708   2                      
 709   2                      case KEY_DOWN:
 710   2                              if(key_io!=0x0f)
 711   2                              {
 712   3                                      if(key_io==0x0e) key_val = 7;
 713   3                                      if(key_io==0x0d) key_val = 6;
 714   3                                      if(key_io==0x0b) key_val = 5;
 715   3                                      if(key_io==0x07) key_val = 4;           
 716   3                                      key_state = KEY_UP;
 717   3                              }
 718   2                              else
 719   2                                      key_state = KEY_NO ;
 720   2                      break;
 721   2                              
 722   2                      case KEY_UP:
 723   2                              if(key_io==0x0f) key_state = KEY_NO;
 724   2                      break;
 725   2              }
 726   1              return key_val;
 727   1      }
