 804          void vSMG_Display()
 805          {
 806   1              static u8 i=0;
 807   1              vDevice_Ctrl(0xc0,0);
 808   1              vDevice_Ctrl(0xe0,~smg_buf[i]);
 809   1              vDevice_Ctrl(0xc0,0x01<<i);
 810   1              i = (i + 1) % 8;
 811   1      }
