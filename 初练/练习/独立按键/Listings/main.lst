 738          u8 cnt_key;
 739          u8 s4_number;
 740          void vBTN_State_Process(void)
 741          {
 742   1              u8 key_val;
 743   1              if(cnt_key>=10)
 744   1              {
 745   2                      cnt_key=0;
 746   2                      key_val = vBTN_Read_State();
 747   2                      if(key_val==4)
 748   2                      {
 749   3                              s4_number++;
 750   3                      }
 751   2              }
 752   1      }
 753          
 754          void vBTN_ThreeLine_Process(void)
 755          {
 756   1              if(cnt_key>=10)
 757   1              {
 758   2                      cnt_key=0;
 759   2                      vBTN_Read_ThreeLine();
 760   2                      if(Trg & 0x08)
 761   2                      {
 762   3                              s4_number++;
 763   3                      }
 764   2                      if(Trg & 0x04)
 765   2                      {
 766   3                              s4_number--;
 767   3                      }
 768   2                      if(Trg & 0x02)
 769   2                      {
 770   3                              s4_number+=10;
 771   3                      }
 772   2                      if(Trg & 0x01)
 773   2                      {
 774   3                              s4_number-=10;
 775   3                      }
 776   2              }
 777   1      }
