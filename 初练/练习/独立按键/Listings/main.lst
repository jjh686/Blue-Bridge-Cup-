 729          unsigned char Trg;
 730          unsigned char Cont;
 731          void vBTN_Read_ThreeLine(void)
 732          {
 733   1              unsigned char ReadData = P3^0xff;
 734   1              Trg = ReadData & (ReadData ^ Cont);
C51 COMPILER V9.56.0.0   MAIN                                                              09/02/2025 15:41:22 PAGE 13  

 735   1              Cont = ReadData;
 736   1      }
