 793          void main(void)
 794          {
 795   1              vSystem_Init();
 796   1              vTimer2_Init();
C51 COMPILER V9.56.0.0   MAIN                                                              09/02/2025 15:41:22 PAGE 14  

 797   1              while(1)
 798   1              {
 799   2                      vSMG_Process();
 800   2                      vBTN_ThreeLine_Process();
 801   2              }
 802   1      }
