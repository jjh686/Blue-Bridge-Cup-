 271          
 272          //定时器(综合练习)
 273          HexToBin led_ctrl,uln_ctrl;
 274          
 275          void vSystem_Init(void)
 276          {
 277   1              vDevice_Ctrl(0xa0,0);           //关闭继电器与蜂鸣器    
 278   1              led_ctrl.hex=0xff;
 279   1              vDevice_Ctrl(0x80,led_ctrl.hex);                //关闭LED
 280   1      }
 281          
 282          void vTimer2_Init(void)         //1毫秒@12.000MHz
 283          {
 284   1              AUXR &= 0xFB;           //定时器时钟12T模式
 285   1              T2L = 0x18;             //设置定时初值
 286   1              T2H = 0xFC;             //设置定时初值
 287   1              AUXR |= 0x10;           //定时器2开始计时
 288   1              IE2 |= 0x04;        //开定时器2中断
 289   1              EA = 1;                         //开启总中断
 290   1      }
 291          
 292          //LED操做函数
 293          u16 cnt_led_blink,cnt_led_running;
 294          u8 led_blink_times,led_shift;
 295          void vLED_Process()
 296          {
 297   1              if(cnt_led_blink>=500)
 298   1              {
 299   2                      cnt_led_blink=0;
 300   2                      led_ctrl.b.b0 = ~led_ctrl.b.b0;
C51 COMPILER V9.56.0.0   MAIN                                                              08/27/2025 16:43:19 PAGE 6   

 301   2                      vDevice_Ctrl(0x80,led_ctrl.hex);
 302   2                      
 303   2                      led_blink_times++;
 304   2              }
 305   1              
 306   1              if(cnt_led_running>=100)
 307   1              {
 308   2                      cnt_led_running=0;
 309   2                      led_ctrl.b.b3 = ~(0x01>>led_shift);
 310   2                      led_ctrl.b.b4 = ~(0x02>>led_shift);
 311   2                      led_ctrl.b.b5 = ~(0x04>>led_shift);
 312   2                      led_ctrl.b.b6 = ~(0x08>>led_shift);
 313   2                      led_ctrl.b.b7 = ~(0x10>>led_shift);
 314   2                      vDevice_Ctrl(0x80,led_ctrl.hex);        
 315   2      
 316   2                      led_shift++;
 317   2                      if(led_shift==5)
 318   2                              led_shift=0;
 319   2              }
 320   1      }
 321          
 322          //继电器操做函数
 323          void vULN_Process()
 324          {
 325   1              if(led_blink_times==10)
 326   1              {
 327   2                      uln_ctrl.b.b4 = 1;
 328   2                      vDevice_Ctrl(0xa0,uln_ctrl.hex);
 329   2              }
 330   1              if(led_blink_times==20)
 331   1              {
 332   2                      led_blink_times=0;
 333   2                      uln_ctrl.b.b4 = 0;
 334   2                      vDevice_Ctrl(0xa0,uln_ctrl.hex);
 335   2              }
 336   1      }
 337          
 338          void main(void)
 339          {
 340   1              vSystem_Init();
 341   1              vTimer2_Init();
 342   1      
 343   1              while(1)
 344   1              {
 345   2      
 346   2              }
 347   1      }
 348          
 349          //中断服务程序
 350          void vTimer_ISR() interrupt 12           //中断入口
 351          {
 352   1              cnt_led_blink++;
 353   1              cnt_led_running++;
 354   1              vLED_Process();
 355   1              vULN_Process();
 356   1      
 357   1      }


