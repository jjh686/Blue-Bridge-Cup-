 426          void main(void)
 427          {
 428   1              vSystem_Init();
 429   1              vTimer2_Init();
 430   1      
 431   1              while(1)
 432   1              {
 433   2      
 434   2              }
 435   1      }
 436          
 437          //中断服务程序
 438          void vTimer_ISR() interrupt 12           //中断入口
 439          {
 440   1              cnt_led_blink++;
 441   1              cnt_led_running++;
 442   1              vLED_Process();
 443   1              vULN_Process();
 444   1      
 445   1      }


