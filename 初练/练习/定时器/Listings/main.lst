 361          HexToBin led_ctrl,uln_ctrl;
 362          
C51 COMPILER V9.56.0.0   MAIN                                                              08/27/2025 17:01:36 PAGE 7   

 363          void vSystem_Init(void)
 364          {
 365   1              vDevice_Ctrl(0xa0,0);           //关闭继电器与蜂鸣器    
 366   1              led_ctrl.hex=0xff;
 367   1              vDevice_Ctrl(0x80,led_ctrl.hex);                //关闭LED
 368   1      }
 369          
 370          void vTimer2_Init(void)         //1毫秒@12.000MHz
 371          {
 372   1              AUXR &= 0xFB;           //定时器时钟12T模式
 373   1              T2L = 0x18;             //设置定时初值
 374   1              T2H = 0xFC;             //设置定时初值
 375   1              AUXR |= 0x10;           //定时器2开始计时
 376   1              IE2 |= 0x04;        //开定时器2中断
 377   1              EA = 1;                         //开启总中断
 378   1      }
 379          
 380          //LED操做函数
 381          u16 cnt_led_blink,cnt_led_running;
 382          u8 led_blink_times,led_shift;
 383          void vLED_Process()
 384          {
 385   1              if(cnt_led_blink>=500)
 386   1              {
 387   2                      cnt_led_blink=0;
 388   2                      led_ctrl.b.b0 = ~led_ctrl.b.b0;
 389   2                      vDevice_Ctrl(0x80,led_ctrl.hex);
 390   2                      
 391   2                      led_blink_times++;
 392   2              }
 393   1              
 394   1              if(cnt_led_running>=100)
 395   1              {
 396   2                      cnt_led_running=0;
 397   2                      led_ctrl.b.b3 = ~(0x01>>led_shift);
 398   2                      led_ctrl.b.b4 = ~(0x02>>led_shift);
 399   2                      led_ctrl.b.b5 = ~(0x04>>led_shift);
 400   2                      led_ctrl.b.b6 = ~(0x08>>led_shift);
 401   2                      led_ctrl.b.b7 = ~(0x10>>led_shift);
 402   2                      vDevice_Ctrl(0x80,led_ctrl.hex);        
 403   2      
 404   2                      led_shift++;
 405   2                      if(led_shift==5)
 406   2                              led_shift=0;
 407   2              }
 408   1      }
 409          
 410          //继电器操做函数
 411          void vULN_Process()
 412          {
 413   1              if(led_blink_times==10)
 414   1              {
 415   2                      uln_ctrl.b.b4 = 1;
 416   2                      vDevice_Ctrl(0xa0,uln_ctrl.hex);
 417   2              }
 418   1              if(led_blink_times==20)
 419   1              {
 420   2                      led_blink_times=0;
 421   2                      uln_ctrl.b.b4 = 0;
 422   2                      vDevice_Ctrl(0xa0,uln_ctrl.hex);
 423   2              }
 424   1      }
