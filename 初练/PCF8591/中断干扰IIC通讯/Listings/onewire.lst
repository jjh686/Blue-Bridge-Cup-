  18          //ЭЈЙ§ЕЅзмЯпЯђDS18B20аДвЛИізжНк
  19          void Write_DS18B20(unsigned char dat)
  20          {
  21   1              unsigned char i;
  22   1              for(i=0;i<8;i++)
  23   1              {
  24   2                      DQ = 0;
