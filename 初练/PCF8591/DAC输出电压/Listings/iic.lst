  71          //Í¨ąýI2C×ÜĎß·˘ËÍĘýľÝ
  72          void IIC_SendByte(unsigned char byt)
  73          {
  74   1          unsigned char i;
  75   1      
  76   1          for(i=0; i<8; i++)
  77   1          {
  78   2              SCL  = 0;
  79   2              IIC_Delay(DELAY_TIME);
