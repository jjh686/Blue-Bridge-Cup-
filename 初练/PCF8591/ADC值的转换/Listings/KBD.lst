  27          /**
  28            * @brief  矩阵键盘 - 状态机法
  29            * @param  None
  30            * @retval key_retrun: 按键的键值，单次触发
  31            * @author dianshe.taobao.com
  32            */
  33          #define KEY_NO   0  //无按键状态，用于判断是否按下
  34          #define KEY_DOWN 1  //有按键按下状态，判断是否为抖动
  35          #define KEY_UP   2  //等待松手状态，判断是否弹起
  36          u8 ucKBD_Read_State()
  37          {
  38   1              static u8 key_state = 0;           // 定义key_state为静态变量，用于保存每次按键的状态
  39   1              u8 key_io = 0, key_retrun = 0; // key_io:读取的IO状态, key_retrun:返回的键值;
  40   1              
  41   1              key_io = ucKBD_KeyIO_State();
  42   1              switch(key_state) 
  43   1              {       
  44   2                      case KEY_NO:                                                                    //无按键状态，用于判断是否按下
  45   2                              if(key_io) key_state = KEY_DOWN; 
  46   2                      break; 
  47   2      
  48   2                      case KEY_DOWN:                                                                  //有按键按下状态，判断是否为抖动
  49   2                              if(key_io)
  50   2                              {
  51   3                                      key_state = KEY_UP;
  52   3                                      key_retrun = key_io;
  53   3                              } 
  54   2                              else 
C51 COMPILER V9.56.0.0   KBD                                                               04/07/2021 23:26:11 PAGE 2   

  55   2                                      key_state = KEY_NO;  
  56   2                      break;  
  57   2                      
  58   2                      case KEY_UP:                                                                    //等待松手状态，判断是否弹起
  59   2                              if(key_io==0) key_state = KEY_NO; 
  60   2                      break; 
  61   2              } 
  62   1              return key_retrun; 
  63   1      }
