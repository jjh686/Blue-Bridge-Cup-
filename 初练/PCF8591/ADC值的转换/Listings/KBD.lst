  67          /**
  68            * @brief  矩阵键盘 - 获取键值
  69            * @param  None
  70            * @retval key_io: 当前按键的键值，按下“位”为低电平
  71            * @author dianshe.taobao.com
  72            */
  73          u8 ucKBD_KeyIO_ThreeLine()
  74          {
  75   1              u8 key_io = 0xff;
  76   1              P3=0xf0;P4=0xff;        //列扫描
  77   1              if(P44==0) key_io=0x70;
  78   1              if(P42==0) key_io=0xb0;
  79   1              if(P35==0) key_io=0xd0;
  80   1              if(P34==0) key_io=0xe0;
  81   1      
  82   1              P3=0x0f;P4=0x00;        //行扫描
  83   1              if(P33==0) key_io=key_io | 0x07;
  84   1              if(P32==0) key_io=key_io | 0x0b;
  85   1              if(P31==0)key_io=key_io | 0x0d;
  86   1              if(P30==0) key_io=key_io | 0x0e;
  87   1              
  88   1              return key_io;
  89   1      }
  90          
