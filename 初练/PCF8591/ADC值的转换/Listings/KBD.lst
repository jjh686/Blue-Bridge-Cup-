   3          /**
   4            * @brief  矩阵键盘 - 获取键值
   5            * @param  None
   6            * @retval key_io: 当前按键的键值，实际的按键标号
   7            * @author dianshe.taobao.com
   8            */
   9          u8 ucKBD_KeyIO_State()
  10          {
  11   1              u8 key_io = 0;
  12   1              P3=0xf0;P4=0xff;        //列扫描
  13   1              if(P44==0) key_io=4;
  14   1              if(P42==0) key_io=8;
  15   1              if(P35==0) key_io=12;
  16   1              if(P34==0) key_io=16;
  17   1      
  18   1              P3=0x0f;P4=0x00;        //行扫描
  19   1              if(P33==0) key_io=key_io + 0;
  20   1              if(P32==0) key_io=key_io + 1;
  21   1              if(P31==0) key_io=key_io + 2;
  22   1              if(P30==0) key_io=key_io + 3;
  23   1              
  24   1              return key_io;
  25   1      }
