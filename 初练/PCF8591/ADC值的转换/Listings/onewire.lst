   7          #include "onewire.h"
   8          
   9          sbit DQ = P1^4;  //单总线接口
  10          
  11          //单总线延时函数
  12          void Delay_OneWire(unsigned int t)  //【注意事项1】STC89C52RC --> IAP15
  13          {
  14   1              t = t * 12;
  15   1              while(t--);
  16   1      }
  17          
  18          //通过单总线向DS18B20写一个字节
  19          void Write_DS18B20(unsigned char dat)
  20          {
  21   1              unsigned char i;
  22   1              for(i=0;i<8;i++)
  23   1              {
  24   2                      DQ = 0;
  25   2                      DQ = dat&0x01;
  26   2                      Delay_OneWire(5);
  27   2                      DQ = 1;
  28   2                      dat >>= 1;
  29   2              }
  30   1              Delay_OneWire(5);
  31   1      }
  32          
  33          //从DS18B20读取一个字节
  34          unsigned char Read_DS18B20(void)
  35          {
  36   1              unsigned char i;
  37   1              unsigned char dat;
  38   1        
  39   1              for(i=0;i<8;i++)
  40   1              {
  41   2                      DQ = 0;
  42   2                      dat >>= 1;
  43   2                      DQ = 1;
  44   2                      if(DQ)
  45   2                      {
  46   3                              dat |= 0x80;
  47   3                      }           
  48   2                      Delay_OneWire(5);
  49   2              }
  50   1              return dat;
  51   1      }
  52          
  53          //DS18B20设备初始化
C51 COMPILER V9.56.0.0   ONEWIRE                                                           04/07/2021 23:26:11 PAGE 2   

  54          bit init_ds18b20(void)
  55          {
  56   1              bit initflag = 0;
  57   1              
  58   1              DQ = 1;
  59   1              Delay_OneWire(12);
  60   1              DQ = 0;
  61   1              Delay_OneWire(80);
  62   1              DQ = 1;
  63   1              Delay_OneWire(10); 
  64   1          initflag = DQ;     
  65   1              Delay_OneWire(5);
  66   1        
  67   1              return initflag;
  68   1      }
  69          
  70          
  71          //需要自己完成读取DS18B20温度的程序
  72          float fRead_Temperature(void)
  73          {
  74   1              float temp_return;
  75   1              u8 low,high;
  76   1              init_ds18b20();
  77   1              Write_DS18B20(0xcc);            //跳过读取ROM
  78   1              Write_DS18B20(0x44);            //启动温度转换
  79   1                                                                      //不加上Delay延时，等待温度转换完成，直接去读取暂存器
  80   1              init_ds18b20();
  81   1              Write_DS18B20(0xcc);            //跳过读取ROM
  82   1              Write_DS18B20(0xbe);            //获取暂存器数据
  83   1              low = Read_DS18B20();           //温度低8位数据
  84   1              high = Read_DS18B20();          //温度高8位数据
  85   1              temp_return = (high<<8|low)*0.0625;
  86   1              
  87   1              return temp_return;
  88   1      }
