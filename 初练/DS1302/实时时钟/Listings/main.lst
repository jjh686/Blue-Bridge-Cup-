   9          #include "system.h"
  10          HexToBin led_ctrl,uln_ctrl;
  11          
  12          /*
  13            * @brief  系统初始化函数：关闭继电器、蜂鸣器
  14            * @param  None
  15            * @retval None
  16            * @author dianshe.taobao.com
  17            */
  18          void vSystem_Init(void)
  19          {
  20   1              vDevice_Ctrl(0xa0,0);                           /* 关闭蜂鸣器、继电器*/
  21   1              led_ctrl.hex=0xff;
  22   1              vDevice_Ctrl(0x80,led_ctrl.hex);        /* 关闭LED*/
  23   1      }
  24          
  25          u8 hour,minute,second;
  26          void vDS1302_Process()
  27          {
  28   1              second = BCDToDec(Read_Ds1302_Byte(0x81));
  29   1              minute = BCDToDec(Read_Ds1302_Byte(0x83));
  30   1              hour = BCDToDec(Read_Ds1302_Byte(0x85));
  31   1      }
  32          
  33          //数码管操作函数
  34          void vSMG_Process()
  35          {
  36   1              smg_buf[0]=smg_code[hour/10];           //旋转电位器的电压值
  37   1              smg_buf[1]=smg_code[hour%10]|0x80;
  38   1              smg_buf[2]=smg_code[minute/10];
  39   1              smg_buf[3]=smg_code[minute%10]|0x80;
  40   1              smg_buf[4]=smg_code[second/10];
  41   1              smg_buf[5]=smg_code[second%10];
  42   1              smg_buf[6]=0x00;
  43   1              smg_buf[7]=0x00;
  44   1      }
  45          
  46          void main(void)
  47          {
  48   1              vSystem_Init();
  49   1              vClock_Set(23,59,55);
  50   1              vTimer2_Init();
  51   1              while(1)
  52   1              {
  53   2                      vSMG_Process();
  54   2                      vDS1302_Process();
